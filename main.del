playervar Boolean spawn_random;

Vector txt_location(in Number X, in Number Y): 
Update(EyePosition(local) + 100 * 
          (X * WorldVectorOf(Right(), local, LocalVector.Rotation) + // X
          (Y // Y
          - 0.200) * DirectionFromAngles(HorizontalAngleFromDirection(Facing(local)), VerticalAngleFromDirection(Facing(local)) - 90) +
          3 * Facing(local)));

rule: "v1.2.1.221030 | Created by scort#12211" 
{
    DisableInspectorRecording(); 
}

rule: "Initial Global"
{
    critexc_arr = [Hero.Ana, Hero.Pharah, Hero.Zarya, Hero.Reinhardt, Hero.Sigma, Hero.Winston, Hero.Junkrat, Hero.Symmetra, Hero.Brigitte, Hero.Moira]; // array of heroes that do NOT crit
    scope_arr = [Hero.Widowmaker, Hero.Ashe, Hero.Ana];
    scope_crit_arr = [Hero.Widowmaker, Hero.Ashe];
    enviro_arr = [Hero.Doomfist, Hero.Pharah, Hero.Lucio, Hero.WreckingBall, Hero.Orisa, Hero.Brigitte, Hero.Junkrat, Hero.Winston, Hero.Sigma, Hero.Zenyatta, Hero.JunkerQueen];

    s_lang = WorkshopSettingCombo("Settings", "Lobby Language", 0, ["English", "日本語"], 0);

    s_match_time = WorkshopSettingCombo("Settings", "Match Time", 2, 
    ["15 minutes", "30 minutes", "45 minutes", 
    "1 hour", "1 hour, 15 minutes", "1 hour, 30 minutes", "1 hour, 45 minutes",
    "2 hours", "2 hours, 15 minutes", "2 hours, 30 minutes", "2 hours, 45 minutes",
    "3 hours", "3 hours, 15 minutes", "3 hours, 30 minutes", "3 hours, 45 minutes",
    "4 hours", "4 hours, 15 minutes"], 1);
    match_time = ((s_match_time + 1) * 15);

    s_instant_respawn = WorkshopSettingToggle("Settings", "Respawn instantly on Interact", true, 2);
    s_killstreak_hud = WorkshopSettingToggle("Settings", "Show Kill Streaks", true, 3);
    s_player_stats = WorkshopSettingToggle("Settings", "Show Player Stats", true, 4);
    s_auto_restart = WorkshopSettingToggle("Settings", "Automatically Restart Lobby After POTG", true, 6);

    s_score_win = WorkshopSettingToggle("Score Win", "Enable Score Win Condition", true, 1);

    s_heal_on_kill = WorkshopSettingToggle("Heal On Kill", "Heal On Kill", true, 1);
    s_hot_time = WorkshopSettingReal("Heal On Kill", "Heal On Kill Duration", 4, 1, 10, 2);
    s_hot_interrupt = WorkshopSettingToggle("Heal On Kill", "Interrupt Heal On Kill upon taking damage", true, 3);
    s_heal = WorkshopSettingInteger("Heal On Kill", "Heal Percentage based on enemies max health", 40, 0, 100, 4) / 100;

    Number credit = WorkshopSettingCombo("Credit", "Created by", 0, ["scort#11221", "saruyo (JP Localization)", "BXRXY", "Please credit!"], 1000);

    SetMatchTime(10);
}

rule: "Initial Player Join"
Event.OnPlayerJoin
{
    kill_streak = 0;
    DisableGameModeHud();
}

rule: "Player Leave"
Event.OnPlayerLeave
{
    kill_streak = 0;
    best_streak = 0;

