playervar Boolean check_spawn;

rule: "v2.0.0.221115 | Created by scort#12211" 
{
    DisableInspectorRecording(); 
}

rule: "Initial Global"
{
    critexc_arr = [Hero.Ana, Hero.Pharah, Hero.Zarya, Hero.Reinhardt, Hero.Sigma, Hero.Winston, Hero.Junkrat, Hero.Symmetra, Hero.Brigitte, Hero.Moira]; // array of heroes that do NOT crit
    scope_arr = [Hero.Widowmaker, Hero.Ashe, Hero.Ana];
    scope_crit_arr = [Hero.Widowmaker, Hero.Ashe];
    enviro_arr = [Hero.Doomfist, Hero.Pharah, Hero.Lucio, Hero.WreckingBall, Hero.Orisa, Hero.Brigitte, Hero.Junkrat, Hero.Winston, Hero.Sigma, Hero.Zenyatta, Hero.JunkerQueen];

    s_lang = WorkshopSettingCombo("Settings", "Default Language", 0, ["English", "日本語"], 0);

    s_match_time = WorkshopSettingInteger("Settings", "Match Time (Minutes)", 45, 5, 60, 1) * 60;
    s_instant_respawn = WorkshopSettingToggle("Settings", "Respawn instantly on Interact", true, 2);
    s_auto_restart = WorkshopSettingToggle("Settings", "Automatically Restart Lobby After POTG", true, 6);
    s_score_win = WorkshopSettingToggle("Settings", "Enable Score Win Condition", true, 1);

    s_menu = WorkshopSettingToggle("Menu", "Use Menu", true, 0);

    s_hud = WorkshopSettingToggle("HUD", "Allow Changing Workshop HUD", true, 1);
    s_def_hud = WorkshopSettingToggle("HUD", "Show Workshop HUD", true, 2);
    s_def_streak = WorkshopSettingToggle("HUD", "Show Kill Streaks", true, 4);
    s_def_stats = WorkshopSettingToggle("HUD", "Show Player Stats", true, 6);

    s_hok = WorkshopSettingToggle("Heal On Kill", "Allow Changing Heal On Kill", true, 7);
    s_def_hok = WorkshopSettingToggle("Heal On Kill", "Heal On Kill", true, 8);
    s_hot_time = WorkshopSettingReal("Heal On Kill", "Heal On Kill Duration", 4, 1, 10, 2);
    s_hot_interrupt = WorkshopSettingToggle("Heal On Kill", "Interrupt Heal On Kill upon taking damage", true, 3);
    s_heal = WorkshopSettingInteger("Heal On Kill", "Heal Percentage based on enemies max health", 40, 0, 100, 4) / 100;

    s_random = WorkshopSettingToggle("Random Hero", "Allow Changing Random Hero", true, 9);
    s_def_random = WorkshopSettingToggle("Random Hero", "Random Hero", false, 10);

    Number credit = WorkshopSettingCombo("Credit", "Created by", 0, ["scort#11221", "saruyo (JP Localization)", "BXRXY", "Please credit!"], 1000);

    SetMatchTime(10);
}

rule: "Initial Player Join"
Event.OnPlayerJoin
{
    // todo: may need some optimization
    if (s_hud && s_def_hud)
    {
        show_all = true;
        show_stats = true;
        show_streak = true;
    }

    if (s_hok && s_def_hok)
        hok = true;

    if (s_random && s_def_random)
        random_hero = true;

    if (s_lang == Lang.EN)
        SetEnglish();
    else 
        SetJapanese();

    sel_item = Item.Invalid;
    fav_item = Item.Invalid;
    HOK_amt = s_heal;

    DisableGameModeHud();
}

