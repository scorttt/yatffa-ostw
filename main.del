rule: "Kick players who havent selected a hero"
Event.OngoingPlayer
if (!HasSpawned())
{
    # 5 minutes
    WaitIfTrue(300);
    SmallMessage(all, <"   <0><1>", player, LANG_STR[5]>);
    Wait(1);
    RemovePlayer(player);
}

rule: "Match Started"
if (IsGameInProgress())
{
    if (!s_score_win)
    {
        DisableCompletion();
        DisableAnnouncer();
    }

    Wait(0.08);
    SetMatchTime(match_time * 60);
    t_left_yellow = (match_time * 60) / 4;
}

void EndMatch() globalvar "End Match Sub"
{
    EnableCompletion();

    if (s_auto_restart)
    {
        Wait(25);
        RestartMatch();
    }
}

rule: "End game after time limit if score win is off"
if (!s_score_win)
if (MatchTime() <= 0)
{
    EndMatch();
}

rule: "Respawn"
Event.OngoingPlayer
if (HasSpawned())
if (IsAlive())
{
    AllowButton(player, Button.Interact);

    if (spawn_random)
    {
        # remove the previous hero from the hero array to re add later to prevent getting the same hero multiple times in a row
        Hero prev_hero = HeroOf();
        Hero[] hero_arr = AllowedHeroes() - prev_hero;

        ForcePlayerHero(player, hero_arr.Random());
        StopForcingHero();

        # add the previous hero back to the hero array
        hero_arr = AllowedHeroes() + prev_hero;
    }

    // workaround for characters spawning with one less hp
    if (Health() != MaxHealth())
        Heal(player, null, MaxHealth());

    // tracer / sym
    if (IsHero(Hero.Tracer) || IsHero(Hero.Symmetra))
        SetAbilityCharge(player, Button.Ability1, 3);

    // junkrat
    if (IsHero(Hero.Junkrat))
        SetAbilityCharge(player, Button.Ability1, 2);

    // dva
    if (IsHero(Hero.Dva))
        SetAbilityResource(player, Button.SecondaryFire, 100);

    // rein
    if (IsHero(Hero.Reinhardt))
        SetAbilityCharge(player, Button.Ability2, 2);

    // pharah
    if (IsHero(Hero.Pharah))
        SetAbilityResource(player, Button.Jump, 100);

    ResetHeroAvailability();

    Wait(0.08);

    SetAmmo(player, 0, MaxAmmo());
    SetAmmo(player, 1, MaxAmmo());
    SetAbilityCooldown(player, Button.Ability1, 0);
    SetAbilityCooldown(player, Button.Ability2, 0);
    SetAbilityCooldown(player, Button.PrimaryFire, 0);
    SetAbilityCooldown(player, Button.SecondaryFire, 0);
}

rule: "Force Respawn"
Event.OngoingPlayer
if (s_instant_respawn)
if (IsButtonHeld(player, Button.Interact))
if (IsDead())
{
    Respawn();
}

rule: "Random Hero Toggle"
Event.OngoingPlayer
if (IsButtonHeld(player, Button.Crouch))
if (IsButtonHeld(player, Button.Melee))
{
    WaitIfTrue(0.5);

    spawn_random = !spawn_random;
    if (spawn_random)
    {
        SmallMessage(player, <"   <0>  <1>", IconString(Icon.Checkmark), LANG_STR[1][2]>);
    }
    else
    {
        SmallMessage(player, <"   <0>  <1>", IconString(Icon.No), LANG_STR[1][3]>);

        # unsure if these are necessary
        ResetHeroAvailability();
        StopForcingHero();
    }
}