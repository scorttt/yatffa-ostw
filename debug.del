rule: "Show Server Load for host and show scort debug info"
Event.OnPlayerJoin
if (player == host || dbg_usrs.Contains(<"<0>", player>))
{
    CreateInWorldText(player, <"C: <0>%, A: <1>%, P: <2>%, T: <3> (<4>)", 
    Near(ServerLoad()), 
    Near(ServerLoadAverage()), 
    Near(ServerLoadPeak()), 
    TextCount(), TextCount() - 1>, RenderPosOf(3, -2.05), 1, Clipping.DoNotClip, InworldTextRev.VisibleToPositionStringAndColor);

    if (dbg_usrs.Contains(<"<0>", player>))
    {
        CreateHudText(player, null, <" \nPos: <0>", PositionOf()>, null, Location.Right, 0.5);
        CreateHudText(player, null, <"Facing: <0>", FacingDirectionOf()>, null, Location.Right, 0.6);
        CreateHudText(player, null, <"RC: <0>", RayCastHitPosition(EyePos(), EyePos() + Facing() * 100, null, all, false)>, null, Location.Right, 0.6);
        CreateHudText(player, null, <"(<0>, <1>)\nsel: <2>\nfav: <3>", CursorX(), CursorY(), sel_item, fav_item>, null, Location.Right, 0.8);
    }
}

