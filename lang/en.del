void SetEnglish() playervar "Menu Option Sub : Set Language to English"
{
    lang_swap = true;
    language = Lang.EN;
    for (Number i = 0; i < EN_STR.Length; i++)
    {
        lang_str[i] = EN_STR[i];
        lang_prog_str =  <"Loading: <0>%", Near(i / EN_STR.Length * 100)>;
        Wait(0.2);
    }

    lang_x = [0.50, // 0
              0.31, // 1
              0.42, // 2
              0.34, // 3
              0.32, // 4
              0.35, // 5
              0.33 // 6
              ];

    lang_prog_str = "Done!";
    Wait(2);
    lang_prog_str = "";
    lang_swap = false;
}