import "../main.del";

playervar Boolean show_all;
playervar Boolean show_stats;
playervar Boolean show_streak;
playervar Boolean hok;
playervar Any HOK_amt;
playervar Boolean random_hero;

playervar Number language;
playervar String lang_prog_str;
playervar Boolean lang_swap;

void ToggleAllHud() playervar "Menu Option Sub : Toggle All HUD"
{
    toggles++;

    show_all = !show_all;
    if (show_all)
    {
        show_stats = true;
        show_streak = true;

        SmallMessage(player, <"   <0>  <1>", IconString(Icon.Checkmark), local.lang_str[6][0]>);
    }
    else 
    {
        show_stats = false;
        show_streak = false;

        SmallMessage(player, <"   <0>  <1>", IconString(Icon.No), local.lang_str[7][0]>);
    }

}

void ToggleStats() playervar "Menu Option Sub : Toggle Stats"
{
    toggles++;
    
    show_stats = !show_stats;
    if (show_stats)
    {
        SmallMessage(player, <"   <0>  <1>", IconString(Icon.Checkmark), local.lang_str[6][1]>);
    }
    else
    {
        SmallMessage(player, <"   <0>  <1>", IconString(Icon.No), local.lang_str[7][1]>);
    }
}

void ToggleStreak() playervar "Menu Option Sub : Toggle Streak"
{
    toggles++;

    show_streak = !show_streak;
    if (show_streak)
    {
        SmallMessage(player, <"   <0>  <1>", IconString(Icon.Checkmark), local.lang_str[6][2]>);
    }
    else
    {
        SmallMessage(player, <"   <0>  <1>", IconString(Icon.No), local.lang_str[7][2]>);
    }
}

void ToggleHOK() playervar "Menu Option Sub : Toggle HOK"
{
    toggles++;

    hok = !hok;
    if (hok)
    {
        SmallMessage(player, <"   <0>  <1>", IconString(Icon.Checkmark), local.lang_str[6][3]>);
    }
    else
    {
        SmallMessage(player, <"   <0>  <1>", IconString(Icon.No), local.lang_str[7][3]>);
    }
}

void ModifyHOK() playervar "Menu Option Sub : Modify HOK"
{
    if (IsPrimaryHeld())
    {
        HOK_amt += 0.025;

        if (HOK_amt > s_heal)
            HOK_amt = 0.025;
    }
    else if (IsSecondaryHeld())
    {
        HOK_amt -= 0.025;

        if (HOK_amt < 0.025)
            HOK_amt = s_heal;
    }
}

void RandomHero() playervar "Menu Option Sub : Random Hero"
{
    toggles++;

    random_hero = !random_hero;
    if (random_hero)
    {
        SmallMessage(player, <"   <0>  <1>", IconString(Icon.Checkmark), local.lang_str[6][5]>);
    }
    else
    {
        SmallMessage(player, <"   <0>  <1>", IconString(Icon.No), local.lang_str[7][5]>);

        # unsure if these are necessary
        ResetHeroAvailability();
        StopForcingHero();
    }
}

void SetEnglish() playervar "Menu Option Sub : Set Language to English"
{
    toggles++;

    lang_swap = true;
    language = Lang.EN;
    for (Number i = 0; i < EN_STR.Length; i++)
    {
        lang_str[i] = EN_STR[i];
        lang_prog_str =  <"Loading: <0>%", Near(i / EN_STR.Length * 100)>;
        Wait(0.25);
    }

    lang_prog_str = "Done!";
    Wait(2);
    lang_prog_str = "";
    lang_swap = false;
}

void SetJapanese() playervar "Menu Option Sub : Set Language to Japanese"
{
    toggles++;

    lang_swap = true;
    language = Lang.JP;
    for (Number i = 0; i < JP_STR.Length; i++)
    {
        lang_str[i] = JP_STR[i];
        lang_prog_str =  <"読み込み：<0>%", Near(i / JP_STR.Length * 100)>;
        Wait(0.25);
    }

    lang_prog_str = "完了！";
    Wait(2);
    lang_prog_str = "";
    lang_swap = false;
}

void SelectionHandler(Number | Item item) playervar "Menu Sub : Selection Handler"
{
    switch (item)
    {
        case Item.AllHUD:
            if (s_hud)
                async! ToggleAllHud();
            break;
        case Item.Stats:
            if (s_hud)
                async! ToggleStats();
            break;
        case Item.Streak:
            if (s_hud)
                async! ToggleStreak();
            break;
        case Item.HOK:
            if (s_hok)
                async! ToggleHOK();
            break;
        case Item.HOKMod:
            if (hok)
                async! ModifyHOK();
            break;
        case Item.Random:
            async! RandomHero();
            break;
        case Item.EN:
            if (language != Lang.EN && !lang_swap)
                async! SetEnglish();
            break;
        case Item.JP:
            if (language != Lang.JP && !lang_swap)
                async! SetJapanese();
            break;
    }

    Wait(0.1);
}