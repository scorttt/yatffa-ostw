                 "English", // 7
                 "日本語", // 8
                 "バランスノート（英語）" // 9
                 ];

    JP_STR[6] = ["Workshop HUD Revealed!", 
                 "Stats Revealed!", 
                 "Kill Streaks Revealed!", 
                 "ヒールオンキルの有効！",
                 "",
                 "ランダムヒーローの有効！",
                 "",
                 "",
